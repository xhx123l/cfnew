        const effectiveRegionMatching = reqRm !== null ? reqRm : enableRegionMatching;
        const effectiveSocksConfig = reqSocksConfig || parsedSocks5Config;
        const effectiveSocksEnabled = reqSocksConfig ? true : isSocksEnabled;

